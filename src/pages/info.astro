---
import BaseLayout from '../layouts/BaseLayout.astro';
import { client } from '../lib/sanity.js';
import imageUrlBuilder from '@sanity/image-url';

const info = await client.fetch(`*[_type == "info"][0]{
  portrait,
  about,
  enquiriesText
}`);

const builder = imageUrlBuilder(client);
function urlFor(source) {
  return builder.image(source).url();
}
---

<BaseLayout title="The Bizness — Info">
console.log('info portrait:', JSON.stringify(info?.portrait, null, 2));
  <main class="info-page">

    <div class="info-top">
      <div class="info-portrait">
        {info?.portrait && (
          <img src={urlFor(info.portrait)} alt="The Bizness" />
        )}
      </div>
      <div class="info-text">
        {info?.about && <p>{info.about}</p>}
      </div>
    </div>

    <div class="info-form-wrap">
      <p class="info-enquiry">{info?.enquiriesText}</p>
      <div class="info-form">
        <div class="info-field">
          <label>Name</label>
          <input type="text">
        </div>
        <div class="info-field">
          <label>Email address</label>
          <input type="email">
        </div>
        <div class="info-field">
          <label>Message</label>
          <textarea></textarea>
        </div>
        <button class="info-send">Send</button>
      </div>
    </div>

  </main>
</BaseLayout>