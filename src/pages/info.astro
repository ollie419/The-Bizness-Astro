---
import BaseLayout from '../layouts/BaseLayout.astro';
import { client } from '../lib/sanity.js';
import imageUrlBuilder from '@sanity/image-url';

const info = await client.fetch(`*[_type == "info"][0]{
  portrait,
  about,
  enquiriesText
}`);

const builder = imageUrlBuilder(client);
function urlFor(source) {
  return builder.image(source).url();
}
---

<BaseLayout title="The Bizness — Info">
  <main class="info-page">

    <div class="info-top">
      <div class="info-portrait"></div>
      <div class="info-text">
        <p>The BIZNESS is a blog.</p>
        <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Proin vitae velit convallis, commodo risus ac, fringilla augue. Sed laoreet dapibus diam eu molestie. Donec hendrerit ex ac nulla finibus dapibus. Nulla facilisi. Praesent dapibus lacus eget nisl laoreet, vitae faucibus massa tristique. Suspendisse fermentum mollis risus, ac dictum est convallis quis. Integer id magna pellentesque, efficitur lectus ut, commodo sem.</p>
        <p>Web design: oworks</p>
      </div>
    </div>

    <div class="info-form-wrap">
      <p class="info-enquiry">For all enquiries please fill out the contact form below and we'll get back to you.</p>
      <div class="info-form">
        <div class="info-field">
          <label>Name</label>
          <input type="text">
        </div>
        <div class="info-field">
          <label>Email address</label>
          <input type="email">
        </div>
        <div class="info-field">
          <label>Message</label>
          <textarea></textarea>
        </div>
        <button class="info-send">Send</button>
      </div>
    </div>

  </main>
</BaseLayout>