---
import BaseLayout from '../layouts/BaseLayout.astro';
import { client } from '../lib/sanity.js';
import imageUrlBuilder from '@sanity/image-url';

const stories = await client.fetch(`*[_type == "story"]{
  name,
  discipline,
  tag,
  blurb,
  slug,
  portrait
}`);

const builder = imageUrlBuilder(client);
function urlFor(source) {
  return builder.image(source).url();
}
---

<BaseLayout title="The Bizness">
  <main class="home">
    <div class="grid">
      {stories.map((story) => (
        <a href={`/story/${story.slug.current}`}>
          <article class="card" data-tag={story.tag}>
            <div class="card-img">
              {story.portrait && (
                <img src={urlFor(story.portrait)} alt={story.name} />
              )}
            </div>
            <div class="card-label">
              <div class="card-name">{story.name.split(' ').map((word) => <>{word}<br/></>)}</div>
              <div class="card-discipline">{story.discipline.split(' ').map((word) => <>{word}<br/></>)}</div>
            </div>
            <div class="card-bar">
              <p class="card-blurb">{story.blurb}</p>
            </div>
          </article>
        </a>
      ))}
    </div>
  </main>
</BaseLayout>