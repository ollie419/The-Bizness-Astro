---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { client } from '../../lib/sanity.js';
import imageUrlBuilder from '@sanity/image-url';

export async function getStaticPaths() {
  const stories = await client.fetch(`*[_type == "story"]{ slug }`);
  return stories.map((story) => ({
    params: { slug: story.slug.current },
  }));
}

const { slug } = Astro.params;
const story = await client.fetch(`*[_type == "story" && slug.current == $slug][0]{
  name,
  discipline,
  location,
  title,
  body,
  imageCredits,
  textCredits,
  portrait,
  slug
}`, { slug });

const builder = imageUrlBuilder(client);
function urlFor(source) {
  return builder.image(source).url();
}
---

<BaseLayout title={`The Bizness — ${story.name}`}>
  <button class="share-btn" onclick="navigator.clipboard.writeText(window.location.href)" aria-label="Share">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 3v13M7 8l5-5 5 5"/>
      <path d="M4 16v3a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-3"/>
    </svg>
  </button>

  <main class="story">
    <div class="story-top">
      <div class="story-portrait">
        {story.portrait && (
          <img src={urlFor(story.portrait)} alt={story.name} />
        )}
      </div>
      <div class="story-meta">
        <div class="story-meta-top">
          <span>{story.name}</span>
          <span>{story.discipline}</span>
          <span>{story.location}</span>
        </div>
      </div>
    </div>

    <div class="story-body">
      <h1 class="story-title">{story.title}</h1>
      <div class="story-credits">
        {story.imageCredits && <span>Images: {story.imageCredits}</span>}
        {story.textCredits && <span>Text: {story.textCredits}</span>}
      </div>
      <div class="story-text">
        {story.body?.map((block) => {
          if (block._type === 'block' && block.children) {
            const text = block.children.map((child) => child.text).join('');
            if (!text) return <br />;
            return <p>{text}</p>;
          }
          return null;
        })}
      </div>
    </div>

    </main>
  <div class="home-btn">
    <a href="/">← Home</a>
  </div>
</BaseLayout>