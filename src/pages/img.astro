---
import BaseLayout from '../layouts/BaseLayout.astro';
import { client } from '../lib/sanity.js';
import imageUrlBuilder from '@sanity/image-url';

const moodboards = await client.fetch(`*[_type == "moodboard"] | order(date desc) {
  _id,
  title,
  date,
  curator,
  images
}`);

const builder = imageUrlBuilder(client);
function urlFor(source) {
  return builder.image(source).url();
}
---

<BaseLayout title="The Bizness — IMG">
  <main class="img-page">
    <div class="img-header">
      <p class="img-curated" id="curatedBy">
        Curated by {moodboards[0]?.curator}
      </p>
      {moodboards.length > 1 && (
        <select class="img-archive" id="archiveSelect">
          {moodboards.map((m, i) => (
            <option value={i}>{m.title || m.date}</option>
          ))}
        </select>
      )}
    </div>

    <div class="img-grid" id="imgGrid">
      {moodboards[0]?.images?.map((image) => (
        <div class="img-item">
          <img src={urlFor(image)} alt="" />
        </div>
      ))}
    </div>
  </main>

  <div class="lightbox" id="lightbox">
    <div class="lightbox-img" id="lightboxImg"></div>
  </div>

  <script define:vars={{ moodboards: moodboards, builderConfig: { projectId: 'rscqwpq1', dataset: 'production' } }}>
    const imgGrid = document.getElementById('imgGrid');
    const curatedBy = document.getElementById('curatedBy');
    const archiveSelect = document.getElementById('archiveSelect');
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightboxImg');

    function urlFor(ref) {
      const id = ref.asset._ref
        .replace('image-', '')
        .replace(/-(\w+)$/, '.$1')
        .replace(/-/g, '/');
      return `https://cdn.sanity.io/images/${builderConfig.projectId}/${builderConfig.dataset}/${id}`;
    }

    function renderMoodboard(index) {
      const m = moodboards[index];
      if (!m) return;
      curatedBy.textContent = `Curated by ${m.curator || ''}`;
      imgGrid.innerHTML = '';
      m.images?.forEach(image => {
        const div = document.createElement('div');
        div.className = 'img-item';
        const img = document.createElement('img');
        img.src = urlFor(image);
        img.alt = '';
        div.appendChild(img);
        imgGrid.appendChild(div);
      });
    }

    archiveSelect?.addEventListener('change', (e) => {
      renderMoodboard(parseInt(e.target.value));
    });

    imgGrid?.addEventListener('click', (e) => {
      const item = e.target.closest('.img-item');
      if (!item) return;
      const img = item.querySelector('img');
      if (!img) return;
      lightboxImg.style.backgroundImage = `url(${img.src})`;
      lightboxImg.style.backgroundSize = 'contain';
      lightboxImg.style.backgroundRepeat = 'no-repeat';
      lightboxImg.style.backgroundPosition = 'center';
      const w = item.offsetWidth;
      const h = item.offsetHeight;
      const ratio = w / h;
      if (ratio >= 1) {
        lightboxImg.style.width = '500px';
        lightboxImg.style.height = 'auto';
        lightboxImg.style.aspectRatio = String(ratio);
      } else {
        lightboxImg.style.height = '500px';
        lightboxImg.style.width = 'auto';
        lightboxImg.style.aspectRatio = String(ratio);
      }
      lightbox.classList.add('open');
    });

    lightbox?.addEventListener('click', () => {
      lightbox.classList.remove('open');
    });
  </script>
</BaseLayout>