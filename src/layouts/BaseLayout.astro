---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import SideIcons from '../components/SideIcons.astro';
const { title = 'The Bizness' } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DIN+Condensed&family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://use.typekit.net/tae4gae.css">
  </head>
  <body>
    <Nav />
    <SideIcons />
    <slot />

    <script>
      // Dark mode persistence
      const moonBtn = document.querySelector('.side-moon')
      if (localStorage.getItem('dark') === '1') {
        document.body.classList.add('dark');
      }
      moonBtn?.addEventListener('click', () => {
        document.body.classList.toggle('dark');
        localStorage.setItem('dark', document.body.classList.contains('dark') ? '1' : '0');
      });

      // Logo shrink on scroll
      const navLogo = document.getElementById('navLogo') ;
      const logoLargeSize = 130;
      const logoSmallSize = 14;
      const shrinkStart = 0;
      const shrinkEnd = 200;
      let isHomePage = window.location.pathname === '/';

      function updateLogo() {
        if (!isHomePage) return;
        const y = window.scrollY;
        const progress = Math.min(Math.max((y - shrinkStart) / (shrinkEnd - shrinkStart), 0), 1);
        const size = logoLargeSize - (logoLargeSize - logoSmallSize) * progress;
        const topStart = 200;
        const topEnd = 40;
        const top = topStart - (topStart - topEnd) * progress;
        if (navLogo) {
          navLogo.style.fontSize = size + 'px';
          navLogo.style.top = top + 'px';
          if (progress >= 1) navLogo.classList.add('scrolled');
          else navLogo.classList.remove('scrolled');
        }
      }

      if (!isHomePage && navLogo) {
        navLogo.classList.add('scrolled');
        navLogo.style.fontSize = '14px';
        navLogo.style.top = '40px';
      }

      window.addEventListener('scroll', updateLogo, { passive: true });
      updateLogo();

      // Tag dropdown
      const navTag = document.querySelector('.nav-tag') ;
      const tagDropdown = document.getElementById('tagDropdown') ;
      const tagItems = document.querySelectorAll('.tag-item');
      const cards = document.querySelectorAll('.card');
      let activeTag = null;

      navTag?.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = tagDropdown.classList.contains('open');
        tagDropdown.classList.toggle('open', !isOpen);
        navTag.classList.toggle('active', !isOpen);
      });

      tagItems.forEach(item => {
        item.addEventListener('click', (e) => {
          e.stopPropagation();
          const tag = (item ).dataset.tag;
          if (activeTag === tag) {
            activeTag = null;
            tagItems.forEach(t => t.classList.remove('active'));
            cards.forEach(c => ((c ).style.display = ''));
          } else {
            activeTag = tag ?? null;
            tagItems.forEach(t => t.classList.remove('active'));
            item.classList.add('active');
            cards.forEach(c => {
              const cardTag = (c ).dataset.tag;
              (c ).style.display = (cardTag === tag) ? '' : 'none';
            });
          }
          tagDropdown.classList.remove('open');
          navTag.classList.remove('active');
        });
      });

      document.addEventListener('click', () => {
        tagDropdown?.classList.remove('open');
        navTag?.classList.remove('active');
      });

      // IMG nav
      document.querySelector('.nav-img')?.addEventListener('click', (e) => {
        e.preventDefault();
        window.location.href = '/img';
      });

      
    </script>
  </body>
</html>