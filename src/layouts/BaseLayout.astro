---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import SideIcons from '../components/SideIcons.astro';
const { title = 'The Bizness' } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DIN+Condensed&family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://use.typekit.net/tae4gae.css">
    <link href="https://api.fontshare.com/v2/css?f[]=rx-100@400&display=swap" rel="stylesheet">
  </head>
  <body>
    <Nav />
    <SideIcons />

    <!-- Mobile nav -->
    <header class="mobile-nav">
      <a class="mobile-logo" href="/">The Bizness</a>
      <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Open menu"></button>
    </header>

    <!-- Mobile menu overlay -->
    <div class="mobile-menu" id="mobileMenu">
      
      <nav class="mobile-menu-links">
        <a href="/info">Info</a>
        <a href="/img">IMG</a>
        <a href="#">Projects</a>
      </nav>
    </div>

    <!-- Mobile bottom bar -->
    <div class="mobile-bottom">
      <button class="mobile-bottom-moon" id="mobileMoon" aria-label="Toggle dark mode">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
      <a class="mobile-bottom-ig" href="https://www.instagram.com/ollie.ade" target="_blank" rel="noopener" aria-label="Instagram">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
        </svg>
      </a>
    </div>

    <slot />

    <script>
      // Dark mode persistence
      const moonBtn = document.querySelector('.side-moon')
      if (localStorage.getItem('dark') === '1') {
        document.body.classList.add('dark');
      }
      moonBtn?.addEventListener('click', () => {
        document.body.classList.toggle('dark');
        localStorage.setItem('dark', document.body.classList.contains('dark') ? '1' : '0');
      });

      // Logo shrink on scroll
      const navLogo = document.getElementById('navLogo') ;
      const logoLargeSize = 130;
      const logoSmallSize = 14;
      const shrinkStart = 0;
      const shrinkEnd = 200;
      let isHomePage = window.location.pathname === '/';

      function updateLogo() {
        if (!isHomePage) return;
        const y = window.scrollY;
        if (y > 200) {
          navLogo.classList.add('scrolled');
        } else {
          navLogo.classList.remove('scrolled');
        }
      }

      if (!isHomePage && navLogo) {
        navLogo.classList.add('scrolled');
      }

      window.addEventListener('scroll', updateLogo, { passive: true });
      updateLogo();

      // Tag dropdown
      const navTag = document.querySelector('.nav-tag') ;
      const tagDropdown = document.getElementById('tagDropdown') ;
      const tagItems = document.querySelectorAll('.tag-item');
      const cards = document.querySelectorAll('.card');
      let activeTag = null;

      navTag?.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = tagDropdown.classList.contains('open');
        tagDropdown.classList.toggle('open', !isOpen);
        navTag.classList.toggle('active', !isOpen);
      });

tagItems.forEach(item => {
        item.addEventListener('click', (e) => {
          e.stopPropagation();
          const tag = item.dataset.tag;
          if (activeTag === tag) {
            activeTag = null;
            tagItems.forEach(t => t.classList.remove('active'));
            cards.forEach(c => (c.style.display = ''));
          } else {
            activeTag = tag ?? null;
            tagItems.forEach(t => t.classList.remove('active'));
            item.classList.add('active');
            cards.forEach(c => {
              const cardTag = c.dataset.tag;
              c.style.display = (cardTag === tag) ? '' : 'none';
            });
          }
          // Keep dropdown open after selection
        });
      });

      document.addEventListener('click', () => {
        tagDropdown?.classList.remove('open');
        navTag?.classList.remove('active');
      });

      // IMG nav
      document.querySelector('.nav-img')?.addEventListener('click', (e) => {
        e.preventDefault();
        window.location.href = '/img';
      });

      // Mobile menu
      const mobileMenuBtn = document.getElementById('mobileMenuBtn');
      const mobileMenuClose = document.getElementById('mobileMenuClose');
      const mobileMenu = document.getElementById('mobileMenu');

      mobileMenuBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = mobileMenu.classList.contains('open');
        if (isOpen) {
          mobileMenu.classList.remove('open');
        } else {
          mobileMenu.classList.add('open');
        }
      });

      mobileMenu?.addEventListener('click', (e) => {
        e.stopPropagation();
      });

      // Mobile dark mode
      const mobileMoon = document.getElementById('mobileMoon');
      mobileMoon?.addEventListener('click', () => {
        document.body.classList.toggle('dark');
        localStorage.setItem('dark', document.body.classList.contains('dark') ? '1' : '0');
      });

      // Mobile card tap — first tap shows blurb, second tap navigates
      function resetCards(except) {
        document.querySelectorAll('.card').forEach(c => {
          if (c === except) return;
          c.classList.remove('tapped');
          const bar = c.querySelector('.card-bar');
          const label = c.querySelector('.card-label');
          if (bar) bar.style.transform = 'translateY(100%)';
          if (label) label.style.transform = 'translateY(0)';
        });
      }

      document.querySelectorAll('.card').forEach(card => {
        card.addEventListener('click', (e) => {
          if (window.innerWidth > 768) return;
          if (!card.classList.contains('tapped')) {
            e.preventDefault();
            e.stopPropagation();
            resetCards(card);
            card.classList.add('tapped');
            const bar = card.querySelector('.card-bar');
            const label = card.querySelector('.card-label');
            if (bar) bar.style.transform = 'translateY(0)';
            if (label) label.style.transform = 'translateY(-120px)';
          }
        });
      });

      // Single document click handler — close menu and reset cards
      document.addEventListener('click', (e) => {
        if (!e.target.closest('.mobile-menu') && !e.target.closest('.mobile-menu-btn')) {
          mobileMenu?.classList.remove('open');
        }
        if (window.innerWidth <= 768 && !e.target.closest('.card')) {
          resetCards(null);
        }
      });
    </script>
  </body>
</html>